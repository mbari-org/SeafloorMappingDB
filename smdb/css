#!/bin/bash
# FOOLPROOF CSS/JS Hot-Reload - Just works, every time
# Usage: ./css  (run from directory that contains smdb/ and production_localhost.yml)
# Copies CSS + map.js into the running container. Runs collectstatic in a new container
# that has env (DATABASE_URL etc.) and sees host files via mount, then copies
# collected staticfiles into the running container.

set -e

echo "⚡ CSS + map.js Hot-Reload"

# Step 1: Copy to SOURCE directory inside the RUNNING container (so running app can use them)
docker cp ./smdb/static/css/leaflet-measure.css smdb_django_1:/app/smdb/static/css/leaflet-measure.css
docker cp ./smdb/static/css/project.css smdb_django_1:/app/smdb/static/css/project.css
docker cp ./smdb/static/css/map.css smdb_django_1:/app/smdb/static/css/map.css
docker cp ./smdb/static/js/map.js smdb_django_1:/app/smdb/static/js/map.js
docker cp ./smdb/static/lib/leaflet-measure smdb_django_1:/app/smdb/static/lib/
# Do NOT copy base.html here — when compress runs with host base.html, measure cursor/dot can disappear. Use full rebuild for base.html changes.
# docker cp ./smdb/templates/base.html smdb_django_1:/app/smdb/templates/base.html
docker cp ./smdb/templates/pages/home.html smdb_django_1:/app/smdb/templates/pages/home.html

# Step 2: Run collectstatic inside the running container (same one we copied files into).
# If the container has no DATABASE_URL (env only in main process), pass a dummy one;
# collectstatic does not use the database.
DB_URL=$(docker exec smdb_django_1 printenv DATABASE_URL 2>/dev/null || true)
if [ -z "$DB_URL" ]; then
  # Dummy postgres URL so settings load; collectstatic never connects
  docker exec -e DATABASE_URL="postgres://localhost:5432/static" smdb_django_1 python manage.py collectstatic --noinput -v0
else
  docker exec smdb_django_1 python manage.py collectstatic --noinput -v0
fi

# Step 2.5: Rebuild compressed CSS/JS (COMPRESS_OFFLINE=True — otherwise base.html {% compress %} stays stale)
if [ -z "$DB_URL" ]; then
  docker exec -e DATABASE_URL="postgres://localhost:5432/static" smdb_django_1 python manage.py compress --force -v0
else
  docker exec smdb_django_1 python manage.py compress --force -v0
fi

# Step 3: Restart Django to reload manifest
docker restart smdb_django_1 > /dev/null
sleep 7

echo "✅ Done! Hard refresh: Ctrl+Shift+R"
echo "🌐 https://smdb-dev.shore.mbari.org/"
